<odoo>
    <record id="product_template_form_view_tour" model="ir.ui.view">
        <field name="name">product.template.form.tour.stop</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <group name="group_general" position="inside">
                <field name="is_tour_stop"/>
                <field name="tour_latitude" invisible="not is_tour_stop"/>
                <field name="tour_longitude" invisible="not is_tour_stop"/>
                <field name="tour_capacity" invisible="not is_tour_stop"/>
                <field name="is_tour_extra"/>
                <field name="tour_extra_pricing" invisible="not is_tour_extra"/>
            </group>
        </field>
    </record>
</odoo>
