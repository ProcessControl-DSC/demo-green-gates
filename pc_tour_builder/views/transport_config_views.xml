<odoo>
    <record id="view_pc_transport_config_list" model="ir.ui.view">
        <field name="name">pc.transport.config.list</field>
        <field name="model">pc.transport.config</field>
        <field name="arch" type="xml">
            <list string="Transport Configurations">
                <field name="name"/>
                <field name="vehicle_type"/>
                <field name="avg_speed_kmh"/>
                <field name="max_hours_leg"/>
                <field name="rest_hours"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_pc_transport_config_form" model="ir.ui.view">
        <field name="name">pc.transport.config.form</field>
        <field name="model">pc.transport.config</field>
        <field name="arch" type="xml">
            <form string="Transport Configuration">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Large truck"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="vehicle_type"/>
                            <field name="avg_speed_kmh"/>
                        </group>
                        <group>
                            <field name="max_hours_leg"/>
                            <field name="rest_hours"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pc_transport_config" model="ir.actions.act_window">
        <field name="name">Transport Configuration</field>
        <field name="res_model">pc.transport.config</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define the transport vehicles used to estimate tour duration
                and to suggest intermediate stops.
            </p>
        </field>
    </record>

    <menuitem id="menu_pc_tour_builder_root"
              name="Tour Builder"
              parent="sale.sale_menu_root"
              sequence="90"/>

    <menuitem id="menu_pc_transport_config"
              name="Transport Configuration"
              parent="menu_pc_tour_builder_root"
              action="action_pc_transport_config"
              sequence="10"/>
</odoo>
