msgid "Origin"
msgstr "Origen"

#. module: pc_tour_builder
msgid "Destination"
msgstr "Destino"

#. module: pc_tour_builder
msgid "Vehicle"
msgstr "Vehículo"

#. module: pc_tour_builder
msgid "Origin city"
msgstr "Ciudad de origen"

#. module: pc_tour_builder
msgid "Destination city"
msgstr "Ciudad de destino"

#. module: pc_tour_builder
msgid "Calculate route"
msgstr "Calcular ruta"

